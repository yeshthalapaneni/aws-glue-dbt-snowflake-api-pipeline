"""
Utility functions for AWS Glue job.

Provides reusable helpers for retries, safe JSON handling, and common
transformations. Keeping these utilities separate makes the main job
script easier to read and maintain.
"""

import time
import logging
from typing import Callable, Any

logger = logging.getLogger(__name__)

# -----------------------------
# Retry Utility
# -----------------------------

def retry(func: Callable, max_retries: int = 3, delay: int = 5, *args, **kwargs) -> Any:
    """
    Generic retry wrapper for functions that may fail intermittently.

    Args:
        func: function to execute
        max_retries: number of retry attempts
        delay: delay between retries in seconds
    """
    attempt = 0

    while attempt <= max_retries:
        try:
            return func(*args, **kwargs)
        except Exception as e:
            attempt += 1

            if attempt > max_retries:
                logger.error(f"Max retries exceeded. Last error: {str(e)}")
                raise

            logger.warning(
                f"Attempt {attempt} failed. Retrying in {delay} seconds. Error: {str(e)}"
            )
            time.sleep(delay)

# -----------------------------
# Data Helpers
# -----------------------------

def ensure_list(data):
    """
    Ensures the API response is always treated as a list.
    Useful when APIs sometimes return a single object instead of a list.
    """
    if isinstance(data, list):
        return data
    return [data]


def add_ingestion_metadata(records, ingestion_time):
    """
    Adds ingestion timestamp to each record.
    This helps with lineage and debugging in downstream systems.
    """
    enriched = []

    for record in records:
        if isinstance(record, dict):
            record["ingestion_timestamp"] = ingestion_time
        enriched.append(record)

    return enriched

# -----------------------------
# Validation Helpers
# -----------------------------

def validate_response(data):
    """
    Basic validation to ensure API response is not empty.
    """
    if not data:
        raise ValueError("API returned empty response")

    return True
